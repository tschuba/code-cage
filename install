#!/bin/sh
set -e
CAGE_DIR="$(cd "$(dirname "$0")" && pwd)"

brew install pngpaste

for bin in cage cage-clipd; do
    ln -sf "$CAGE_DIR/$bin" "/usr/local/bin/$bin"
    echo "Linked $bin"
done

# WezTerm reminder
if ! grep -q 'cage-clipboard' "$HOME/.wezterm.lua" 2>/dev/null; then
    cat <<'MSG'

WezTerm config not yet updated. Add this to the config.keys table in ~/.wezterm.lua:

  {
    key = 'v',
    mods = 'CTRL|SHIFT',
    action = wezterm.action.SendString(os.getenv('HOME') .. '/.cage-clipboard/latest.png'),
  },

Ctrl+Shift+V then inserts the clipboard image path into the prompt.

MSG
else
    echo "WezTerm config already contains cage-clipboard binding"
fi
