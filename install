#!/bin/sh
set -e
CAGE_DIR="$(cd "$(dirname "$0")" && pwd)"

if ! python3 -c '' 2>/dev/null; then
    echo "cage-clipd requires Python 3 (ships with macOS 12+). Please install it." >&2
    exit 1
fi

# Store GitHub token in sbx secret store so agents can push, create PRs, etc.
if gh auth token >/dev/null 2>&1; then
    echo "Importing GitHub token into sbx secrets..."
    gh auth token | sbx secret set -g github 2>/dev/null || \
        echo "  (skipped: sbx not yet authenticated — run 'sbx login' first)"
else
    echo "Note: 'gh' not authenticated — run 'gh auth login' then 'sbx secret import github' to enable git/GitHub in cage sessions"
fi

for bin in cage cage-clipd; do
    ln -sf "$CAGE_DIR/$bin" "/usr/local/bin/$bin"
    echo "Linked $bin"
done

# WezTerm reminder
if ! grep -q 'cage/clipboard' "$HOME/.wezterm.lua" 2>/dev/null; then
    cat <<'MSG'

WezTerm config not yet updated. Add this to the config.keys table in ~/.wezterm.lua:

  {
    key = 'v',
    mods = 'CTRL|SHIFT',
    action = wezterm.action_callback(function(window, pane)
      local f = io.open(os.getenv('HOME') .. '/.cage/clipboard/.current', 'r')
      if f then
        local text = f:read('*a'):gsub('\n$', '')
        f:close()
        pane:send_text(text)
      end
    end),
  },

Ctrl+Shift+V then inserts the clipboard path(s) from ~/.cage/clipboard/.current into the prompt.

MSG
else
    echo "WezTerm config already contains cage-clipboard binding"
fi
