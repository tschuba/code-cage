#!/bin/sh
set -e
SCRIPT="$(readlink "$0" || echo "$0")"
CAGE_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
AGENT="${1:-claude}"
shift 2>/dev/null || true
KIT="$CAGE_DIR/${AGENT}-kit"
KIT_KIND="$(grep '^kind:' "$KIT/spec.yaml" 2>/dev/null | awk '{print $2}')"
NAME="${AGENT}-$(basename "$(pwd)" | tr -cs 'a-zA-Z0-9.' '-' | sed 's/-$//')"

# Start clipboard daemon if not already running
if ! pgrep -qf cage-clipd 2>/dev/null; then
    mkdir -p "$HOME/.cage/clipboard"
    "$CAGE_DIR/cage-clipd" >/dev/null 2>&1 &
fi

sbx rm -f "$NAME" 2>/dev/null || true
printf '\033]0;⬡ cage:%s\007' "$AGENT"
wezterm cli set-tab-title "⬡ cage:$AGENT" 2>/dev/null || true
if [ "$KIT_KIND" = "agent" ]; then
  exec sbx run "$AGENT" --kit "$KIT" --name "$NAME" . "$HOME/.claude:ro" "$HOME/.cage/clipboard:ro" -- "$@"
else
  exec sbx run "$AGENT" --kit "$KIT" --name "$NAME" . "$HOME/.claude:ro" "$HOME/.cage/clipboard:ro" -- --dangerously-skip-permissions "$@"
fi
