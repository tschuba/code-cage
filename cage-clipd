#!/bin/sh
# cage-clipd — sync clipboard images to ~/.cage-clipboard/latest.png
# Requires: brew install pngpaste
set -e

OUTDIR="$HOME/.cage-clipboard"
mkdir -p "$OUTDIR"

if ! command -v pngpaste >/dev/null 2>&1; then
    echo "cage-clipd: pngpaste not found. Run: brew install pngpaste" >&2
    exit 1
fi

prev_hash=""
while true; do
    hash=$(osascript -e 'clipboard info' 2>/dev/null | md5 || echo "")
    if [ "$hash" != "$prev_hash" ]; then
        prev_hash="$hash"
        pngpaste "$OUTDIR/latest.png" 2>/dev/null || rm -f "$OUTDIR/latest.png"
    fi
    sleep 0.3
done
